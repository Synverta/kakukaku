# PostgreSQL / 阿里云 PolarDB 连接串
# 格式: postgresql://用户名:密码@主机:端口/数据库名?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@synverta.pg.polardb.rds.aliyuncs.com:5432/kakukaku?sslmode=require

# 后端服务端口
PORT=6002

# JWT 签名密钥（生产请用长随机字符串）
JWT_SECRET=replace-me-with-a-long-random-string

# 支付宝（占位，留待接入）
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY=
ALIPAY_ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=

# 微信支付（占位，留待接入）
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_V3_KEY=
WECHAT_NOTIFY_URL=
